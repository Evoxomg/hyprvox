[global]
    monitor = 0
    follow = mouse
    width = 360
    height = 120
    origin = top-right
    offset = 20x45
    scale = 0
    notification_limit = 6

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_corner_radius = 8

    transparency = 10
    corner_radius = 0
    frame_width = 2
    gap_size = 10
    separator_height = 0
    padding = 14
    horizontal_padding = 14
    text_icon_padding = 12

    icon_corner_radius = 0
    min_icon_size = 32
    max_icon_size = 48

    font = JetBrainsMono Nerd Font 10
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#2E3440EE"
    foreground = "#D8DEE9"
    frame_color = "#4C566A"
    timeout = 4

[urgency_normal]
    background = "#2E3440EE"
    foreground = "#ECEFF4"
    frame_color = "#5E81AC"
    timeout = 6

[urgency_critical]
    background = "#3B4252EE"
    foreground = "#ECEFF4"
    frame_color = "#BF616A"
    timeout = 0
